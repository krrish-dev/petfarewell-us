---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import FAQSection from '../../../../components/FAQSection.astro';
import { generateBreadcrumbs } from '../../../../lib/breadcrumb';
import { buildLocalBusinessSchema, buildBreadcrumbSchema } from '../../../../lib/schema';
import { SITE_CONFIG } from '../../../../config/site';
import { getAllLocations } from '../../../../lib/locations';

export async function getStaticPaths() {
  const locations = await getAllLocations();
  const eligibleLocations = locations.filter(loc => loc.data.services.includes('pet-cremation'));
  return eligibleLocations.map(loc => ({
    params: { state: loc.data.stateSlug, city: loc.data.citySlug },
    props: { location: loc }
  }));
}

const { location } = Astro.props;
const { cityName, stateName, businessName, address, telephone = SITE_CONFIG.nap.telephone, geo, serviceArea, nearbyAreas = [] } = location.data;
const title = `Pet Cremation & Aftercare in ${cityName}, ${stateName}`;
const description = `Private and communal pet cremation aftercare coordination in ${cityName}, ${stateName}.`;
const canonicalUrl = new URL(Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`, SITE_CONFIG.url).href;
const breadcrumbItems = generateBreadcrumbs(Astro.url.pathname, SITE_CONFIG.url);
const breadcrumbJsonLd = buildBreadcrumbSchema(breadcrumbItems);
const localBusinessJsonLd = buildLocalBusinessSchema({ businessName, address, telephone, geo, url: canonicalUrl, services: ['pet-cremation'], serviceArea, nearbyAreas });
const faqItems = [
  { question: `Do you help with pet cremation in ${cityName}?`, answer: `Yes. Pet Farewell can coordinate aftercare options for families in ${cityName}.` },
  { question: 'What is private cremation?', answer: 'Private cremation means ashes are returned to the family.' },
  { question: 'What is communal cremation?', answer: 'Communal cremation is a respectful option where ashes are not returned.' }
];
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl} structuredData={[localBusinessJsonLd, breadcrumbJsonLd]}>
  <div class="container">
    <Breadcrumb items={breadcrumbItems} />
    <div class="service-location-page content-container">
      <header class="page-header">
        <h1>Pet Cremation & Aftercare in {cityName}, {stateName}</h1>
        <p class="lead">Respectful aftercare options for families in {cityName}.</p>
      </header>
      <section class="service-details">
        <h2>Cremation Options</h2>
        <div class="options-grid">
          <div class="card option-card"><h3>Private Cremation</h3><p>Ashes are returned to your family.</p></div>
          <div class="card option-card"><h3>Communal Cremation</h3><p>A respectful option when ashes do not need to be returned.</p></div>
        </div>
        <div class="contact-box card">
          <p><strong>{businessName}</strong></p>
          <p>Mobile service for {cityName} and nearby communities.</p>
          <p class="phone"><strong>Call or text:</strong> <a href={`tel:${SITE_CONFIG.nap.telephoneHref}`}>{telephone}</a></p>
        </div>
      </section>
      <FAQSection items={faqItems} title={`Pet Cremation FAQs for ${cityName}`} />
    </div>
  </div>
</BaseLayout>

<style>
  .service-location-page { padding: var(--space-xl) 0 var(--space-4xl); }
  .page-header { margin-bottom: var(--space-2xl); text-align: center; }
  .lead { font-size: var(--font-size-xl); color: var(--color-text-secondary); max-width: 36rem; margin: 0 auto; }
  .options-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin: var(--space-xl) 0 var(--space-2xl); }
  .option-card h3 { color: var(--color-primary); margin-top: 0; }
  .contact-box { background: var(--color-primary-subtle); border-color: var(--color-primary-light); margin: var(--space-lg) 0; }
  .contact-box p { margin-bottom: var(--space-xs); }
  .phone { margin-top: var(--space-md); font-size: var(--font-size-lg); }
  .phone a { color: var(--color-primary-dark); }
  @media (max-width: 768px) { .options-grid { grid-template-columns: 1fr; } }
</style>