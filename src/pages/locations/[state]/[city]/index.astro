---
import LocationPageLayout from '../../../../layouts/LocationPageLayout.astro';
import { SITE_CONFIG } from '../../../../config/site';
import { getAllLocations } from '../../../../lib/locations';

export async function getStaticPaths() {
  const locations = await getAllLocations();
  return locations.map(loc => ({
    params: { 
      state: loc.data.stateSlug,
      city: loc.data.citySlug
    },
    props: { location: loc }
  }));
}

const { location } = Astro.props;
const {
  cityName,
  stateName,
  businessName,
  address,
  telephone = SITE_CONFIG.nap.telephone,
  geo,
  services,
  serviceArea,
  serviceRadius,
  localIntro,
  nearbyAreas = [],
} = location.data;

const description = `In-home pet euthanasia in ${cityName}, ${stateName} by ${SITE_CONFIG.brandName}. Mobile dog and cat euthanasia, compassionate guidance, and cremation aftercare coordination.`;
---

<LocationPageLayout
  title={`In-Home Pet Euthanasia in ${cityName}, ${stateName}`}
  description={description}
  businessName={businessName}
  address={address}
  telephone={telephone}
  geo={geo}
  services={services}
  serviceArea={serviceArea}
  serviceRadius={serviceRadius}
  localIntro={localIntro}
  nearbyAreas={nearbyAreas}
>
  <div class="location-about">
    <h2>Mobile Dog and Cat Euthanasia for {cityName} Families</h2>
    <p>Pet Farewell provides calm, respectful in-home end-of-life care for dogs and cats in {cityName}. The goal is to avoid a stressful clinic visit and allow your pet to remain in a familiar place, surrounded by the people who know them best.</p>
    
    <p>Dr. Hany Soliman helps families understand the process, answer quality-of-life questions, and plan aftercare before the appointment. Visits are handled with sedation first, private family time, and a peaceful final medication only when your pet is deeply relaxed.</p>

    <h3>What This {cityName} Service Page Covers</h3>
    <ul>
      <li><strong>At-home pet euthanasia:</strong> mobile veterinary visit for dogs and cats in a familiar home setting.</li>
      <li><strong>Pet hospice guidance:</strong> practical support when you are unsure whether it is the right time.</li>
      <li><strong>Aftercare coordination:</strong> communal or private cremation options when requested.</li>
      <li><strong>Local scheduling:</strong> appointment availability depends on route timing, distance, and your pet's needs.</li>
    </ul>

    <h3>When Families Usually Call</h3>
    <p>Families in {cityName} usually reach out when a pet is no longer eating well, cannot stand comfortably, is struggling to breathe, is in uncontrolled pain, or has more difficult days than good days. A phone conversation can help clarify the next step without pressure.</p>

    <div class="contact-cta">
      <h3>Talk With Pet Farewell About {cityName} Availability</h3>
      <p>Call or text <a href={`tel:${SITE_CONFIG.nap.telephoneHref}`}>{telephone}</a> to ask about appointment timing, pricing, cremation choices, and whether an in-home visit is appropriate for your dog or cat.</p>
    </div>
  </div>
</LocationPageLayout>

<style>
  .location-about h2 {
    margin-top: 0;
  }

  .location-about h3 {
    margin-top: var(--space-xl);
  }

  .contact-cta {
    background: var(--color-bg-warm);
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    margin-top: var(--space-2xl);
    border-left: 4px solid var(--color-primary);
  }

  .contact-cta h3 {
    margin-top: 0;
  }

  .contact-cta p:last-child {
    margin-bottom: 0;
  }
</style>