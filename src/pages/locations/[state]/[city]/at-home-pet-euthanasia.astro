---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import FAQSection from '../../../../components/FAQSection.astro';
import { generateBreadcrumbs } from '../../../../lib/breadcrumb';
import { buildLocalBusinessSchema, buildBreadcrumbSchema } from '../../../../lib/schema';
import { SITE_CONFIG } from '../../../../config/site';
import { getAllLocations } from '../../../../lib/locations';

export async function getStaticPaths() {
  const locations = await getAllLocations();
  const eligibleLocations = locations.filter(loc => loc.data.services.includes('at-home-pet-euthanasia'));
  
  return eligibleLocations.map(loc => ({
    params: { 
      state: loc.data.stateSlug,
      city: loc.data.citySlug
    },
    props: { location: loc }
  }));
}

const { location } = Astro.props;
const {
  cityName,
  stateName,
  businessName,
  address,
  telephone = SITE_CONFIG.nap.telephone,
  geo,
  serviceArea,
  nearbyAreas = [],
} = location.data;

const title = `At-Home Pet Euthanasia in ${cityName}, ${stateName}`;
const description = `Peaceful at-home dog and cat euthanasia in ${cityName}, ${stateName}. Mobile veterinary end-of-life care with sedation, family privacy, and aftercare options.`;

const canonicalUrl = new URL(Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`, SITE_CONFIG.url).href;

const breadcrumbItems = generateBreadcrumbs(Astro.url.pathname, SITE_CONFIG.url);
const breadcrumbJsonLd = buildBreadcrumbSchema(breadcrumbItems);

const localBusinessJsonLd = buildLocalBusinessSchema({
  businessName,
  address,
  telephone,
  geo,
  url: canonicalUrl,
  services: ['at-home-pet-euthanasia'],
  serviceArea,
  nearbyAreas,
});

const faqItems = [
  {
    question: `Do you offer at-home euthanasia appointments in ${cityName}?`,
    answer: `Yes. Pet Farewell provides mobile in-home euthanasia visits for dogs and cats in ${cityName} when scheduling and route availability allow. Call or text ${telephone} to discuss timing, distance, and your pet's condition.`
  },
  {
    question: `What happens during an in-home euthanasia visit in ${cityName}?`,
    answer: 'The visit starts with time for questions and a comfort-focused assessment. A sedative is given first so your pet can relax into deep sleep. The final medication is given only after your pet is fully comfortable and your family is ready.'
  },
  {
    question: 'Can Pet Farewell help with cremation after the visit?',
    answer: 'Yes. Families can request aftercare coordination, including communal cremation or private cremation when ashes should be returned.'
  }
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  structuredData={[localBusinessJsonLd, breadcrumbJsonLd]}
>
  <div class="container">
    <Breadcrumb items={breadcrumbItems} />

    <div class="service-location-page content-container">
      <header class="page-header">
        <h1>At-Home Pet Euthanasia in {cityName}, {stateName}</h1>
        <p class="lead">A peaceful, pain-free transition for your dog or cat in the comfort of home.</p>
      </header>

      <section class="service-details">
        <h2>Why Choose At-Home Euthanasia?</h2>
        <p>For many pets, a veterinary clinic can add fear and confusion to an already difficult day. An in-home visit allows your pet to rest in a familiar room, on their own bed, near their family, without a final car ride or waiting room.</p>
        
        <p>{businessName} helps {cityName} families plan a calm goodbye with clear communication, gentle sedation, and time for privacy before and after the passing.</p>

        <h2>Our Gentle Process</h2>
        <div class="process-steps">
          <div class="step card">
            <h3>1. Arrival & Questions</h3>
            <p>Dr. Hany Soliman arrives for the mobile visit, confirms your pet's comfort needs, answers final questions, and explains each step before anything begins.</p>
          </div>
          <div class="step card">
            <h3>2. Comfort Sedation</h3>
            <p>A gentle sedative helps your dog or cat fall into a deep, pain-free sleep while family can remain close.</p>
          </div>
          <div class="step card">
            <h3>3. Peaceful Passing & Aftercare</h3>
            <p>The final medication is given after your pet is fully relaxed. If cremation is selected, respectful transportation and aftercare coordination can be arranged.</p>
          </div>
        </div>

        {nearbyAreas.length > 0 && (
          <div class="nearby-note card">
            <h2>Nearby Areas Often Served from {cityName}</h2>
            <p>{nearbyAreas.join(', ')}</p>
          </div>
        )}

        <div class="contact-box card">
          <p><strong>Schedule an Appointment or Consultation in {cityName}</strong></p>
          <p class="phone"><a href={`tel:${SITE_CONFIG.nap.telephoneHref}`}>{telephone}</a></p>
          <p class="mt-sm"><em>We are here to support you in making the kindest decision for your pet.</em></p>
        </div>
      </section>

      <FAQSection items={faqItems} title={`At-Home Pet Euthanasia FAQs for ${cityName}`} />
    </div>
  </div>
</BaseLayout>

<style>
  .service-location-page {
    padding: var(--space-xl) 0 var(--space-4xl);
  }

  .page-header {
    margin-bottom: var(--space-2xl);
    text-align: center;
  }

  .lead {
    font-size: var(--font-size-xl);
    color: var(--color-text-secondary);
    max-width: 36rem;
    margin: 0 auto;
  }

  .process-steps {
    display: grid;
    gap: var(--space-md);
    margin: var(--space-xl) 0 var(--space-2xl);
  }

  .step h3,
  .nearby-note h2 {
    color: var(--color-primary);
    margin-top: 0;
  }

  .nearby-note {
    margin: var(--space-2xl) 0;
    background: var(--color-bg-warm);
  }

  .contact-box {
    background: var(--color-primary-subtle);
    border-color: var(--color-primary-light);
    margin: var(--space-2xl) 0;
    text-align: center;
    padding: var(--space-2xl) var(--space-xl);
  }

  .contact-box p {
    margin-bottom: 0;
  }

  .phone {
    margin-top: var(--space-md);
    font-size: var(--font-size-2xl);
    font-weight: 700;
  }

  .phone a {
    color: var(--color-primary-dark);
    text-decoration: none;
  }
  
  .mt-sm {
    margin-top: var(--space-sm);
  }
</style>