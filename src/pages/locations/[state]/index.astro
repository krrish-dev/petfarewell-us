---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HeroSection from '../../../components/HeroSection.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { generateBreadcrumbs } from '../../../lib/breadcrumb';
import { buildBreadcrumbSchema } from '../../../lib/schema';
import { SITE_CONFIG } from '../../../config/site';

export async function getStaticPaths() {
  const locations = await getCollection('locations');
  const states = Array.from(new Set(locations.map(loc => loc.data.stateSlug)));
  
  return states.map(stateSlug => {
    const stateLocations = locations.filter(loc => loc.data.stateSlug === stateSlug);
    return {
      params: { state: stateSlug },
      props: { 
        stateName: stateLocations[0].data.stateName,
        cities: stateLocations 
      },
    };
  });
}

const { state } = Astro.params;
const { stateName, cities } = Astro.props;

const title = `Pet Farewell Services in ${stateName}`;
const description = `Find compassionate pet cremation and at-home euthanasia services in ${stateName}. View our locations and available care options.`;

const breadcrumbItems = generateBreadcrumbs(Astro.url.pathname, SITE_CONFIG.url);
const breadcrumbJsonLd = buildBreadcrumbSchema(breadcrumbItems);

const sortedCities = cities.sort((a, b) => a.data.cityName.localeCompare(b.data.cityName));
---

<BaseLayout
  title={title}
  description={description}
  structuredData={breadcrumbJsonLd}
>
  <div class="container">
    <Breadcrumb items={breadcrumbItems} />
  </div>

  <HeroSection
    headline={`Pet End-of-Life Care in ${stateName}`}
    subheadline={`Providing dignified, compassionate services for families throughout ${stateName}.`}
    ctaText="Find Your City"
    ctaHref="#cities"
  />

  <div class="container section" id="cities">
    <div class="content-container">
      <h2>Available Locations in {stateName}</h2>
      <p>Select your city to view contact information, service areas, and available options for your pet's care.</p>

      <ul class="cities-list">
        {sortedCities.map(city => (
          <li>
            <a href={`/locations/${state}/${city.data.citySlug}/`} class="card city-card">
              <div class="city-info">
                <h3>{city.data.cityName}</h3>
                <span class="city-services">{city.data.services.length} services available</span>
              </div>
              <span class="arrow">→</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</BaseLayout>

<style>
  .cities-list {
    list-style: none;
    padding: 0;
    margin: var(--space-xl) 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-lg);
  }

  .city-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    text-decoration: none;
    padding: var(--space-lg);
  }

  .city-info h3 {
    margin: 0 0 var(--space-xs) 0;
    color: var(--color-primary);
    font-size: var(--font-size-lg);
  }

  .city-services {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  .arrow {
    color: var(--color-primary);
    font-size: var(--font-size-xl);
    transition: transform var(--transition-fast);
  }

  .city-card:hover .arrow {
    transform: translateX(4px);
  }
</style>
