---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HeroSection from '../../../components/HeroSection.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { generateBreadcrumbs } from '../../../lib/breadcrumb';
import { buildBreadcrumbSchema } from '../../../lib/schema';
import { SITE_CONFIG } from '../../../config/site';
import { getAllLocations } from '../../../lib/locations';

export async function getStaticPaths() {
  const locations = await getAllLocations();
  const states = Array.from(new Set(locations.map(loc => loc.data.stateSlug)));
  
  return states.map(stateSlug => {
    const stateLocations = locations.filter(loc => loc.data.stateSlug === stateSlug);
    return {
      params: { state: stateSlug },
      props: { 
        stateName: stateLocations[0].data.stateName,
        cities: stateLocations 
      },
    };
  });
}

const { state } = Astro.params;
const { stateName, cities } = Astro.props;

const title = `In-Home Pet Euthanasia Service Areas in ${stateName}`;
const description = `Find ${stateName} city pages for Pet Farewell in-home dog euthanasia, cat euthanasia, pet hospice guidance, and cremation aftercare coordination.`;

const breadcrumbItems = generateBreadcrumbs(Astro.url.pathname, SITE_CONFIG.url);
const breadcrumbJsonLd = buildBreadcrumbSchema(breadcrumbItems);

const sortedCities = cities.sort((a, b) => a.data.cityName.localeCompare(b.data.cityName));
---

<BaseLayout
  title={title}
  description={description}
  structuredData={breadcrumbJsonLd}
>
  <div class="container">
    <Breadcrumb items={breadcrumbItems} />
  </div>

  <HeroSection
    headline={`In-Home Pet Euthanasia in ${stateName}`}
    subheadline="Mobile dog and cat euthanasia, quality-of-life guidance, and cremation aftercare coordination."
    ctaText="Find Your City"
    ctaHref="#cities"
  />

  <div class="container section" id="cities">
    <div class="content-container">
      <h2>Available {stateName} Service Areas</h2>
      <p>Select the closest city page for local details, nearby communities, service-area notes, and appointment guidance. Pet Farewell uses mobile service-area pages instead of fake clinic locations.</p>

      <ul class="cities-list">
        {sortedCities.map(city => (
          <li>
            <a href={`/locations/${state}/${city.data.citySlug}/`} class="card city-card">
              <div class="city-info">
                <h3>{city.data.cityName}</h3>
                <span class="city-services">In-home euthanasia + aftercare coordination</span>
              </div>
              <span class="arrow">→</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</BaseLayout>

<style>
  .cities-list {
    list-style: none;
    padding: 0;
    margin: var(--space-xl) 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-lg);
  }

  .city-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    text-decoration: none;
    padding: var(--space-lg);
  }

  .city-info h3 {
    margin: 0 0 var(--space-xs) 0;
    color: var(--color-primary);
    font-size: var(--font-size-lg);
  }

  .city-services {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  .arrow {
    color: var(--color-primary);
    font-size: var(--font-size-xl);
    transition: transform var(--transition-fast);
  }

  .city-card:hover .arrow {
    transform: translateX(4px);
  }
</style>