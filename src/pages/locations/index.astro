---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import { generateBreadcrumbs } from '../../lib/breadcrumb';
import { buildBreadcrumbSchema } from '../../lib/schema';
import { SITE_CONFIG } from '../../config/site';
import { getAllLocations } from '../../lib/locations';

const title = 'Service Areas for In-Home Pet Euthanasia';
const description = 'Pet Farewell service areas for in-home dog euthanasia, cat euthanasia, pet hospice guidance, and cremation aftercare coordination in Southern California.';

const locations = await getAllLocations();

const uniqueStates = Array.from(new Set(locations.map(loc => loc.data.stateName)))
  .map(stateName => {
    const loc = locations.find(l => l.data.stateName === stateName);
    return {
      name: stateName,
      slug: loc?.data.stateSlug,
      count: locations.filter(l => l.data.stateName === stateName).length,
    };
  })
  .sort((a, b) => a.name.localeCompare(b.name));

const priorityCities = locations
  .sort((a, b) => a.data.cityName.localeCompare(b.data.cityName))
  .slice(0, 120);

const breadcrumbItems = generateBreadcrumbs(Astro.url.pathname, SITE_CONFIG.url);
const breadcrumbJsonLd = buildBreadcrumbSchema(breadcrumbItems);
---

<BaseLayout
  title={title}
  description={description}
  structuredData={breadcrumbJsonLd}
>
  <HeroSection
    headline="Southern California In-Home Pet Euthanasia Service Areas"
    subheadline="Mobile dog and cat euthanasia, hospice guidance, and aftercare coordination by appointment."
    ctaText="Find Your City"
    ctaHref="#cities"
  />

  <div class="container section">
    <div class="content-container">
      <h2>Select Your State</h2>
      <p>Pet Farewell is built around real mobile service areas, not fake clinic addresses. Choose your state, then select the nearest city page for localized appointment and aftercare information.</p>

      <ul class="states-list">
        {uniqueStates.map(state => (
          <li>
            <a href={`/locations/${state.slug}/`} class="card state-card">
              <span>
                <strong>{state.name}</strong>
                <small>{state.count} service areas</small>
              </span>
              <span class="arrow">→</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="container section" id="cities">
    <div class="content-container">
      <h2>Priority City Pages</h2>
      <p>These pages target high-intent local searches such as “in-home pet euthanasia near me”, “dog euthanasia at home”, and “cat euthanasia at home” with city-specific content.</p>
      <ul class="cities-list">
        {priorityCities.map(city => (
          <li>
            <a href={`/locations/${city.data.stateSlug}/${city.data.citySlug}/`} class="card city-card">
              <span>{city.data.cityName}, {city.data.address?.state || 'CA'}</span>
              <span class="arrow">→</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</BaseLayout>

<style>
  .states-list,
  .cities-list {
    list-style: none;
    padding: 0;
    margin: var(--space-xl) 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: var(--space-lg);
  }

  .state-card,
  .city-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    text-decoration: none;
    padding: var(--space-lg);
  }

  .state-card strong,
  .city-card span:first-child {
    color: var(--color-primary);
    font-size: var(--font-size-lg);
  }

  .state-card small {
    display: block;
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    margin-top: var(--space-xs);
  }

  .arrow {
    color: var(--color-primary);
    font-size: var(--font-size-xl);
    transition: transform var(--transition-fast);
  }

  .state-card:hover .arrow,
  .city-card:hover .arrow {
    transform: translateX(4px);
  }
</style>