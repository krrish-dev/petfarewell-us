const description = "Learn about pet burial options, including dedicated pet cemeteries and the laws and best practices surrounding backyard pet burial.";

const headline = "Pet Burial Options and Guidance";
const subheadline = "Exploring dignified resting places for your pet, whether at a dedicated cemetery or a loving home burial.";

const headings = [
  { depth: 2, slug: "pet-cemeteries", text: "Dedicated Pet Cemeteries" },
  { depth: 2, slug: "home-burial", text: "Home Burial Considerations" },
  { depth: 2, slug: "environmental-concerns", text: "Environmental and Legal Concerns" }
];

const faqItems = [
  {
    question: "Is it legal to bury my pet in my backyard?",
    answer: "In many municipalities, it is legal to bury a pet on private property that you own, but local laws vary wildly. You must check with your local city or county government to ensure you are complying with zoning and environmental regulations."
  },
  {
    question: "How deep should a pet grave be?",
    answer: "Generally, a pet should be buried at least 3 to 4 feet deep to prevent scavengers from disturbing the site and to comply with most local health regulations."
  }
