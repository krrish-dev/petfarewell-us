---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Page Not Found | Pet Farewell";
const description = "The page you are looking for does not exist.";
---

<BaseLayout
  title={title}
  description={description}
  noindex={true}
>
  <div class="container section text-center not-found-page">
    <h1>404</h1>
    <h2>Page Not Found</h2>
    <p>We're sorry, but the page you are looking for doesn't exist or has been moved.</p>
    <a href="/" class="btn btn-primary mt-lg">Return to Homepage</a>
  </div>
</BaseLayout>

<style>
  .text-center {
    text-align: center;
  }
  
  .not-found-page {
    padding: var(--space-4xl) 0;
    min-height: 60vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .not-found-page h1 {
    font-size: 6rem;
    color: var(--color-primary);
    margin: 0 0 var(--space-sm) 0;
    line-height: 1;
  }

  .not-found-page h2 {
    margin-top: 0;
  }

  .mt-lg {
    margin-top: var(--space-lg);
  }
</style>
