const headline = "Compassionate Pet Hospice Care";
const subheadline = "Prioritizing your pet's comfort and quality of life when a cure is no longer possible.";

const headings = [
  { depth: 2, slug: "what-is-pet-hospice", text: "What is Pet Hospice?" },
  { depth: 2, slug: "palliative-care-focus", text: "The Focus of Palliative Care" },
  { depth: 2, slug: "when-to-consider", text: "When to Consider Hospice Care" },
  { depth: 2, slug: "supporting-the-family", text: "Supporting the Family" }
];

const faqItems = [
  {
    question: "Does hospice care mean I am giving up on my pet?",
    answer: "No. Hospice care means you are shifting the focus from curing the illness to ensuring your pet is as comfortable and happy as possible for the time they have left."
  },
  {
    question: "How long can a pet be in hospice care?",
    answer: "Hospice care can last anywhere from a few days to several months, depending on the pet's condition, the disease progression, and the family's wishes."
