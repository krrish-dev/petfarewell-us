---
/**
 * MobileCallBar.astro
 * Fixed bottom call-to-action for mobile visitors.
 */
import { SITE_CONFIG } from '../config/site';

const phoneHref = 'tel:+17609120848';
---

<a class="mobile-call-bar" href={phoneHref} aria-label={`Call now ${SITE_CONFIG.nap.telephone}`}>
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M7.1 4.5 8.7 8c.3.7.2 1.5-.3 2.1l-.8.9c1 1.9 2.5 3.4 4.4 4.4l.9-.8c.6-.5 1.4-.6 2.1-.3l3.5 1.6c.8.4 1.2 1.2 1 2.1l-.5 2.1c-.2.8-.9 1.4-1.8 1.4C9.1 21.5 2.5 14.9 2.5 6.8c0-.9.6-1.6 1.4-1.8L6 4.5c.4-.1.8-.1 1.1 0Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
  <span>Call now {SITE_CONFIG.nap.telephone}</span>
</a>

<style>
  .mobile-call-bar {
    display: none;
  }

  @media (max-width: 768px) {
    :global(body) {
      padding-bottom: calc(5.25rem + env(safe-area-inset-bottom));
    }

    .mobile-call-bar {
      position: fixed;
      left: var(--space-md);
      right: var(--space-md);
      bottom: calc(var(--space-sm) + env(safe-area-inset-bottom));
      z-index: 95;
      min-height: 4.25rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-sm);
      padding: var(--space-md) var(--space-lg);
      border-radius: var(--radius-lg);
      background: var(--color-primary);
      color: white;
      font-size: var(--font-size-lg);
      font-weight: 800;
      text-decoration: none;
      box-shadow: var(--shadow-xl);
    }

    .mobile-call-bar:hover {
      color: white;
      background: var(--color-primary-dark);
    }

    .mobile-call-bar svg {
      flex-shrink: 0;
    }
  }

  @media (max-width: 360px) {
    .mobile-call-bar {
      font-size: var(--font-size-base);
      padding-left: var(--space-md);
      padding-right: var(--space-md);
    }
  }
</style>
