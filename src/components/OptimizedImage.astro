---
/**
 * OptimizedImage.astro
 * Thin wrapper around Astro's <Image> component.
 * Enforces explicit width/height and WebP format.
 * Requires non-empty alt prop (or alt="" for decorative).
 */
import { Image } from 'astro:assets';

interface Props {
  src: ImageMetadata | string;
  alt: string;
  width: number;
  height: number;
  class?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
}

const { src, alt, width, height, class: className, loading = 'lazy', fetchpriority } = Astro.props;
---

{typeof src === 'string' ? (
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    class={className}
    loading={loading}
    fetchpriority={fetchpriority}
    decoding="async"
  />
) : (
  <Image
    src={src}
    alt={alt}
    width={width}
    height={height}
    format="webp"
    class={className}
    loading={loading}
    fetchpriority={fetchpriority}
    decoding="async"
  />
)}
