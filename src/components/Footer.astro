---
/**
 * Footer.astro
 * Site footer with NAP, service links, resources, locations, legal links,
 * and a contextual link to the primary service website.
 */
import { SITE_CONFIG } from '../config/site';

const serviceLinks = [
  { label: 'In-Home Pet Euthanasia', href: '/at-home-pet-euthanasia/' },
  { label: 'Cost & Pricing', href: '/cost/' },
  { label: 'Pet Hospice Care', href: '/pet-hospice/' },
  { label: 'Cremation & Aftercare', href: '/pet-cremation/' },
];

const companyLinks = [
  { label: 'About Dr. Hany', href: '/about/' },
  { label: 'Contact', href: '/contact/' },
  { label: 'FAQ', href: '/faq/' },
  { label: 'Service Areas', href: '/locations/' },
];

const cityLinks = [
  { label: 'Victorville', href: '/locations/california/victorville/' },
  { label: 'Apple Valley', href: '/locations/california/apple-valley/' },
  { label: 'Hesperia', href: '/locations/california/hesperia/' },
  { label: 'Barstow', href: '/locations/california/barstow/' },
  { label: 'Riverside', href: '/locations/california/riverside/' },
];

const legalLinks = [
  { label: 'Privacy Policy', href: '/privacy-policy/' },
  { label: 'Terms of Service', href: '/terms-of-service/' },
];

const currentYear = new Date().getFullYear();
---

<footer class="site-footer" id="site-footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand Column -->
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label={`${SITE_CONFIG.name} — Home`}>
          <svg class="logo-icon" width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <circle cx="16" cy="16" r="14" fill="var(--color-primary)" opacity="0.15"/>
            <path d="M10 12c0-1.1.9-2 2-2s2 .9 2 2-.9 2-2 2-2-.9-2-2zm8 0c0-1.1.9-2 2-2s2 .9 2 2-.9 2-2 2-2-.9-2-2zm-8 6c0 3.3 2.7 6 6 6s6-2.7 6-6H10z" fill="var(--color-primary)"/>
          </svg>
          <span>{SITE_CONFIG.name}</span>
        </a>
        <p class="footer-description">
          In-home dog euthanasia and cat euthanasia with respectful cremation and aftercare coordination for Southern California families.
        </p>
        {SITE_CONFIG.nap.telephone && (
          <div class="footer-nap">
            <a href={`tel:${SITE_CONFIG.nap.telephoneHref}`} class="footer-phone">
              {SITE_CONFIG.nap.telephone}
            </a>
          </div>
        )}
        {SITE_CONFIG.nap.email && (
          <div class="footer-nap">
            <a href={`mailto:${SITE_CONFIG.nap.email}`} class="footer-email">
              {SITE_CONFIG.nap.email}
            </a>
          </div>
        )}
      </div>

      <!-- Services Column -->
      <div class="footer-column">
        <h3 class="footer-heading">Services</h3>
        <ul class="footer-links">
          {serviceLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Company Column -->
      <div class="footer-column">
        <h3 class="footer-heading">Company</h3>
        <ul class="footer-links">
          {companyLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- City Column -->
      <div class="footer-column">
        <h3 class="footer-heading">Popular Areas</h3>
        <ul class="footer-links">
          {cityLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Legal Column -->
      <div class="footer-column">
        <h3 class="footer-heading">Legal</h3>
        <ul class="footer-links">
          {legalLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-primary-service">
        Primary service website:
        <a href="https://pethomeeuthanasiaservice.com/">Pet Home Euthanasia Service</a>
      </p>
      <p>&copy; {currentYear} {SITE_CONFIG.brandName}. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-text);
    color: hsl(220, 10%, 75%);
    padding: var(--space-3xl) 0 var(--space-xl);
    margin-top: auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr repeat(4, 1fr);
    gap: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid hsla(220, 10%, 75%, 0.15);
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
    color: white;
    font-family: var(--font-heading);
    font-size: var(--font-size-xl);
    font-weight: 700;
    margin-bottom: var(--space-md);
  }

  .footer-description {
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--space-md);
    max-width: 28rem;
  }

  .footer-nap a {
    color: hsl(220, 10%, 75%);
    text-decoration: none;
    font-size: var(--font-size-sm);
    transition: color var(--transition-fast);
  }

  .footer-nap a:hover {
    color: white;
  }

  .footer-heading {
    color: white;
    font-size: var(--font-size-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-md);
    margin-top: 0;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: var(--space-sm);
  }

  .footer-links a {
    color: hsl(220, 10%, 68%);
    text-decoration: none;
    font-size: var(--font-size-sm);
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: white;
  }

  .footer-bottom {
    padding-top: var(--space-xl);
    text-align: center;
    font-size: var(--font-size-sm);
  }

  .footer-bottom p {
    margin-bottom: var(--space-sm);
  }

  .footer-bottom p:last-child {
    margin-bottom: 0;
  }

  .footer-primary-service a {
    color: hsl(220, 10%, 86%);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer-primary-service a:hover {
    color: white;
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-xl);
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>