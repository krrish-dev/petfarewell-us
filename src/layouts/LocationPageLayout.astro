---
/**
 * LocationPageLayout.astro
 * Layout for city service area pages.
 * Extends BaseLayout with VeterinaryCare JSON-LD, NAP display, and breadcrumbs.
 */
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { generateBreadcrumbs } from '../lib/breadcrumb';
import { buildLocalBusinessSchema, buildBreadcrumbSchema } from '../lib/schema';
import { SITE_CONFIG } from '../config/site';

interface Address {
  streetAddress?: string;
  city: string;
  state: string;
  postalCode?: string;
  country: string;
}

interface Geo {
  latitude: number;
  longitude: number;
}

interface Props {
  title: string;
  description: string;
  businessName: string;
  address?: Address;
  telephone?: string;
  geo?: Geo;
  services: string[];
  serviceArea?: string;
  serviceRadius?: string;
  nearbyAreas?: string[];
  localIntro?: string;
}

const {
  title,
  description,
  businessName,
  address,
  telephone = SITE_CONFIG.nap.telephone,
  geo,
  services,
  serviceArea,
  serviceRadius,
  nearbyAreas = [],
  localIntro,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`, SITE_CONFIG.url).href;

const breadcrumbItems = generateBreadcrumbs(Astro.url.pathname, SITE_CONFIG.url);
const breadcrumbJsonLd = buildBreadcrumbSchema(breadcrumbItems);

const localBusinessJsonLd = buildLocalBusinessSchema({
  businessName,
  address,
  telephone,
  geo,
  url: canonicalUrl,
  services,
  serviceArea,
  nearbyAreas,
});

const serviceLabels: Record<string, string> = {
  'pet-cremation': 'Pet Cremation & Aftercare',
  'at-home-pet-euthanasia': 'At-Home Pet Euthanasia',
};

const corePlanningLinks = [
  { label: 'Home', href: '/', description: 'Pet Farewell homepage' },
  { label: 'Cost & Pricing', href: '/cost/', description: 'Euthanasia and cremation package pricing' },
  { label: 'In-Home Pet Euthanasia', href: '/at-home-pet-euthanasia/', description: 'Dog and cat euthanasia at home process' },
  { label: 'FAQ', href: '/faq/', description: 'Common questions about scheduling and aftercare' },
  { label: 'Pet Cremation', href: '/pet-cremation/', description: 'Private and communal cremation options' },
];

const hasPublicAddress = Boolean(address?.streetAddress);
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  structuredData={[localBusinessJsonLd, breadcrumbJsonLd]}
>
  <div class="container">
    <Breadcrumb items={breadcrumbItems} />

    <div class="location-page content-container">
      <header class="location-header">
        <h1>{title}</h1>
        {localIntro && <p class="location-lead">{localIntro}</p>}
      </header>

      <!-- Mobile service NAP Display Block -->
      <section class="nap-block card" id="nap">
        <h2 class="nap-title">Contact Information</h2>
        <div class="nap-details">
          <div class="nap-item">
            <span class="nap-label">Business</span>
            <span class="nap-value">{businessName}</span>
          </div>
          <div class="nap-item">
            <span class="nap-label">Address</span>
            {hasPublicAddress ? (
              <address class="nap-value nap-address">
                {address?.streetAddress}<br />
                {address?.city}, {address?.state} {address?.postalCode}
              </address>
            ) : (
              <span class="nap-value">Mobile in-home veterinary visit. No public clinic address is used for appointments.</span>
            )}
          </div>
          <div class="nap-item">
            <span class="nap-label">Phone</span>
            <a href={`tel:${SITE_CONFIG.nap.telephoneHref}`} class="nap-value nap-phone">{telephone}</a>
          </div>
          {serviceArea && (
            <div class="nap-item">
              <span class="nap-label">Service Area</span>
              <span class="nap-value">{serviceArea}</span>
            </div>
          )}
          {serviceRadius && (
            <div class="nap-item">
              <span class="nap-label">Coverage</span>
              <span class="nap-value">{serviceRadius}</span>
            </div>
          )}
        </div>
      </section>

      {nearbyAreas.length > 0 && (
        <section class="nearby-areas card" id="nearby-areas">
          <h2>Nearby Communities Served</h2>
          <p>Families often contact Pet Farewell from surrounding neighborhoods and nearby communities, including:</p>
          <ul class="nearby-list">
            {nearbyAreas.map((area) => <li>{area}</li>)}
          </ul>
        </section>
      )}

      <!-- Available Services -->
      <section class="available-services" id="services">
        <h2>Available Services</h2>
        <div class="services-grid">
          {services.map(service => (
            <a
              href={`${Astro.url.pathname.replace(/\/$/, '')}/${service}/`}
              class="card service-card"
            >
              <h3>{serviceLabels[service] || service}</h3>
              <span class="service-arrow">→</span>
            </a>
          ))}
        </div>
      </section>

      <section class="planning-links card" id="planning-links">
        <h2>Plan an In-Home Visit</h2>
        <p>Use these core pages to compare cost, understand the process, and choose aftercare before scheduling.</p>
        <ul class="planning-list">
          {corePlanningLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
              <span>{link.description}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- Page Content Slot -->
      <div class="location-content">
        <slot />
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .location-page {
    padding: var(--space-xl) 0 var(--space-4xl);
  }

  .location-header {
    margin-bottom: var(--space-xl);
  }

  .location-lead {
    color: var(--color-text-secondary);
    font-size: var(--font-size-lg);
    line-height: var(--line-height-relaxed);
    margin-top: var(--space-md);
  }

  .nap-block,
  .nearby-areas,
  .planning-links {
    margin-bottom: var(--space-2xl);
  }

  .nap-title,
  .nearby-areas h2,
  .planning-links h2 {
    font-size: var(--font-size-xl);
    margin-top: 0;
    margin-bottom: var(--space-lg);
  }

  .nap-details {
    display: grid;
    gap: var(--space-md);
  }

  .nap-item {
    display: flex;
    gap: var(--space-md);
  }

  .nap-label {
    font-weight: 600;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    min-width: 6rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .nap-value {
    color: var(--color-text);
    font-style: normal;
  }

  .nap-phone {
    color: var(--color-primary);
    font-weight: 600;
  }

  .nearby-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    list-style: none;
    margin: var(--space-md) 0 0;
    padding: 0;
  }

  .nearby-list li {
    background: var(--color-primary-subtle);
    border: 1px solid var(--color-primary-light);
    border-radius: var(--radius-full);
    color: var(--color-primary-dark);
    font-size: var(--font-size-sm);
    padding: 0.35rem 0.75rem;
  }

  .available-services {
    margin-bottom: var(--space-2xl);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  .service-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    text-decoration: none;
  }

  .service-card h3 {
    color: var(--color-primary);
    font-size: var(--font-size-lg);
    margin: 0;
  }

  .service-arrow {
    font-size: var(--font-size-xl);
    color: var(--color-primary);
    transition: transform var(--transition-fast);
  }

  .service-card:hover .service-arrow {
    transform: translateX(4px);
  }

  .planning-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-md);
    list-style: none;
    margin: var(--space-lg) 0 0;
    padding: 0;
  }

  .planning-list li {
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    padding: var(--space-md);
  }

  .planning-list a {
    color: var(--color-primary);
    display: block;
    font-weight: 700;
    text-decoration: none;
  }

  .planning-list span {
    color: var(--color-text-secondary);
    display: block;
    font-size: var(--font-size-sm);
    margin-top: var(--space-xs);
  }

  .location-content {
    line-height: var(--line-height-relaxed);
  }

  @media (max-width: 768px) {
    .nap-item {
      flex-direction: column;
      gap: var(--space-xs);
    }
  }
</style>